{
  "name": "danebertram.com",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "yarn start",
    "start": "yarn build:css && ELEVENTY_ENV=development eleventy --serve",
    "build": "yarn build:css && eleventy",
    "build:css": "sass css/main.scss css/main.css --style=compressed --no-source-map",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .eleventy.js scripts",
    "lint:fix": "oxlint --fix .eleventy.js scripts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dbertram/danebertram.com_v3.git"
  },
  "author": "Dane Bertram",
  "homepage": "https://github.com/dbertram/danebertram.com_v3#readme",
  "dependencies": {},
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "sass": "^1.97.3"
  }
}
